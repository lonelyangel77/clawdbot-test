		lineageTag: 9e1ea54c-ad9f-4014-b127-e25fba1dbfa0

	measure 'ROW_YTD Budget Var%' = DIVIDE([ROW_YTD Sales (Rs)]-[ROW_Budget_YTD],[ROW_Budget_YTD])
