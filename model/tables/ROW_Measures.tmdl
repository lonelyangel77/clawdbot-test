	measure 'ROW_MTD Budget Var%' = DIVIDE([ROW_MTD Sales]-[ROW_MTD Budget],[ROW_MTD Budget])
		dataType: variant
		formatString: #,##0.00%
		displayFolder: Budget\Variance
