	measure 'Per Day Units Sold' =
			var NoOfDaysPassed =
			VAR _Yesterday = [Yesterday Date]
			RETURN
			CALCULATE(
			    COUNTROWS('Calendar'),
			    FILTER(
			        ALL('Calendar'[Date]),
			        'Calendar'[Date] <= _Yesterday &&
			        MONTH('Calendar'[Date]) = MONTH(_Yesterday) &&
			        YEAR('Calendar'[Date]) = YEAR(_Yesterday)
			    )
			)
			VAR sellthru = [MTD Sales (U)]
			
			Return
			DIVIDE(sellthru,NoOfDaysPassed)
		dataType: variant
		formatString: #,0
		displayFolder: Productivity
		lineageTag: 5528ba27-ba37-4d97-8640-be352e650f57

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Per Day Units Sold YTD' =
			
			VAR NoOfDaysPassed =
			    VAR _Yesterday = [Yesterday Date]
			    RETURN
			    CALCULATE(
			        COUNTROWS('Calendar'),
			        FILTER(
			            ALL('Calendar'[Date]),
			            'Calendar'[Date] <= _Yesterday &&
			            YEAR('Calendar'[Date]) = YEAR(_Yesterday)
			        )
			    )
			VAR sellthru = [YTD Sales (U)]
			RETURN
			DIVIDE(sellthru, NoOfDaysPassed)
		dataType: variant
		formatString: #,0
		displayFolder: Productivity
		lineageTag: 0ce5d71f-831f-4052-b848-71dde844cf6c

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Per Day Sell Thru%' =
			var NoOfDaysPassed =
			VAR _Yesterday = [Yesterday Date]
			RETURN
			CALCULATE(
			    COUNTROWS('Calendar'),
			    FILTER(
			        ALL('Calendar'[Date]),
			        'Calendar'[Date] <= _Yesterday &&
			        MONTH('Calendar'[Date]) = MONTH(_Yesterday) &&
			        YEAR('Calendar'[Date]) = YEAR(_Yesterday)
			    )
			)
			VAR sellthru = [SellThru%_MTD]
			
			Return
			DIVIDE(sellthru,NoOfDaysPassed)
		dataType: variant
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Productivity
		lineageTag: deabcf33-c131-4ed5-8d18-f0d7066f2de6

	measure 'Per Day SellThru% YTD' =
			
			VAR NoOfDaysPassed =
			    VAR _Yesterday = [Yesterday Date]
			    RETURN
			    CALCULATE(
			        COUNTROWS('Calendar'),
			        FILTER(
			            ALL('Calendar'[Date]),
			            'Calendar'[Date] <= _Yesterday &&
			            YEAR('Calendar'[Date]) = YEAR(_Yesterday)
			        )
			    )
			VAR sellthru = [SellThru%_YTD]
			RETURN
			DIVIDE(sellthru, NoOfDaysPassed)
		dataType: variant
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Productivity
		lineageTag: f5aad628-2087-4cd4-9c3b-9a92d330ed42

