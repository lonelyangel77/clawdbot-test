	measure Bottom5Stores = ```
			
			VAR BottomStores =
			    TOPN(
			        5,
			        SUMMARIZE(
			            SALES,
			            SALES[Store],
			            "TotalSales", SUM(SALES[NetAmount])
			        ),
			        [TotalSales],
			        ASC
			    )
			RETURN
			SUMX(BottomStores, [TotalSales])
			
			```
