	column 'Fiscal Month' =
			IF('Calendar'[Month Name]="January","07",
			IF('Calendar'[Month Name]="February","08",
			IF('Calendar'[Month Name]="March","09",
			IF('Calendar'[Month Name]="April","10",
			IF('Calendar'[Month Name]="May","11",
			IF('Calendar'[Month Name]="June","12",
			IF('Calendar'[Month Name]="July","01",
			IF('Calendar'[Month Name]="August","02",
			IF('Calendar'[Month Name]="September","03",
			IF('Calendar'[Month Name]="October","04",
			IF('Calendar'[Month Name]="November","05",
			IF('Calendar'[Month Name]="December","06"))))))))))))
		dataType: string
		lineageTag: 7bbe9d32-e0e3-486a-82dd-d5f35896ee2a
		summarizeBy: none
		isDataTypeInferred

		annotation SummarizationSetBy = Automatic

	column '''Date' =
			
			VAR TodaysDate =
			    TODAY ()
			VAR YesterdayDate =
			    TODAY () - 1
			VAR NextMondaysDate =
			    SWITCH (
			        TRUE (),
			        'Calendar'[Date] - WEEKDAY ( 'Calendar'[Date], 2 )
			            + 1
			            >= TodaysDate, 'Calendar'[Date] - WEEKDAY ( 'Calendar'[Date], 2 )
			            + 1,
			        TODAY () - 9
			    )
			VAR NextWorkingDay =
			    SWITCH (
			        TRUE (),
			        'Calendar'[Date] = TodaysDate, "Today",
			        'Calendar'[Date] = YesterdayDate, "Yesterday",
			        "Work Day"
			    )
			RETURN
			    NextWorkingDay
		dataType: string
		lineageTag: d83b8a35-0bcb-4c7a-81c7-1b9c8e95e74b
		summarizeBy: none
		isDataTypeInferred

		annotation SummarizationSetBy = Automatic

