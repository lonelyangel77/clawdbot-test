	column 'Fiscal Year' = ```
			IF(AND([Date (Year)] ="2012",[Date (Month Index)]<=12),"FY-2012-13",
			IF(AND([Date (Year)] ="2013",[Date (Month Index)]<=6),"FY-2012-13",
			IF(AND([Date (Year)] ="2013",[Date (Month Index)]<=12),"FY-2013-14",        
			IF(AND([Date (Year)] ="2014",[Date (Month Index)]<=6),"FY-2013-14",
			IF(AND([Date (Year)] ="2014",[Date (Month Index)]<=12),"FY-2014-15",
			IF(AND([Date (Year)] ="2015",[Date (Month Index)]<=6),"FY-2014-15",
			IF(AND([Date (Year)] ="2015",[Date (Month Index)]<=12),"FY-2015-16",
			IF(AND([Date (Year)] ="2016",[Date (Month Index)]<=6),"FY-2015-16",
			IF(AND([Date (Year)] ="2016",[Date (Month Index)]<=12),"FY-2016-17",
			IF(AND([Date (Year)] ="2017",[Date (Month Index)]<=6),"FY-2016-17",
			IF(AND([Date (Year)] ="2017",[Date (Month Index)]<=12),"FY-2017-18",
			IF(AND([Date (Year)] ="2018",[Date (Month Index)]<=6),"FY-2017-18",
			IF(AND([Date (Year)] ="2018",[Date (Month Index)]<=12),"FY-2018-19",
			IF(AND([Date (Year)] ="2019",[Date (Month Index)]<=6),"FY-2018-19",
			IF(AND([Date (Year)] ="2019",[Date (Month Index)]<=12),"FY-2019-20",
			IF(AND([Date (Year)] ="2020",[Date (Month Index)]<=6),"FY-2019-20",
			IF(AND([Date (Year)] ="2020",[Date (Month Index)]<=12),"FY-2020-21",
			IF(AND([Date (Year)] ="2021",[Date (Month Index)]<=6),"FY-2020-21",
			IF(AND([Date (Year)] ="2021",[Date (Month Index)]<=12),"FY-2021-22",
			IF(AND([Date (Year)] ="2022",[Date (Month Index)]<=6),"FY-2021-22",
			IF(AND([Date (Year)] ="2022",[Date (Month Index)]<=12),"FY-2022-23",
			IF(AND([Date (Year)] ="2023",[Date (Month Index)]<=6),"FY-2022-23",
			IF(AND([Date (Year)] ="2023",[Date (Month Index)]<=12),"FY-2023-24",
			IF(AND([Date (Year)] ="2024",[Date (Month Index)]<=6),"FY-2023-24",
			IF(AND([Date (Year)] ="2024",[Date (Month Index)]<=12),"FY-2024-25",
			IF(AND([Date (Year)] ="2025",[Date (Month Index)]<=6),"FY-2024-25",
			IF(AND([Date (Year)] ="2025",[Date (Month Index)]<=12),"FY-2025-26",
			IF(AND([Date (Year)] ="2026",[Date (Month Index)]<=6),"FY-2025-26",
			IF(AND([Date (Year)] ="2026",[Date (Month Index)]<=12),"FY-2026-27",
			IF(AND([Date (Year)] ="2027",[Date (Month Index)]<=6),"FY-2026-27",
			IF(AND([Date (Year)] ="2027",[Date (Month Index)]<=12),"FY-2027-28",
			" ")))))))))))))))))))))))))))))))
			```
		dataType: string
