	measure 'Sales Indicator PP KPI' =
			var positive_icon = "🔺"
			
			    var negative_icon = "🔻"
			
			    var result = IF([YTD ForeCast Var%]>0, positive_icon, negative_icon)
			
			    return result
		dataType: variant
		displayFolder: Indicators
		lineageTag: c8dca216-c780-4b5a-8328-f701ca24cd38

		annotation PBI_FormatHint = {"isGeneralNumber":true}

