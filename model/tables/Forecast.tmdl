table Forecast
	isHidden

	measure 'ME Forecast' = [Current Daily Avg]*[Total No. of Days]
		dataType: variant
		displayFolder: Run Rate
		lineageTag: 5e0ff757-3fef-43fc-88a3-868eb22eadc1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'EoM Sales' = SUM(Targets[Target])*(1 + [MTD TGT Var% %])
		dataType: variant
		formatString: #,0
		displayFolder: Run Rate
		lineageTag: aa89087e-2141-4104-8ab7-bffa3ed71a71

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Current Daily Avg' = [Sale-Value]/[Days Passed]
		dataType: variant
		formatString: #,0
		displayFolder: Run Rate
		lineageTag: e27b9f3c-7357-4ca7-bc8b-e4ec03f2594e

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Req Avg' = ([TGT]-[Sale-Value])/[DaysLeft]
		dataType: variant
		displayFolder: Run Rate
		lineageTag: 9d3462bc-d81b-4d14-9937-f23d7c05ddb6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Remaining Sales' = [Current Daily Avg]*[DaysLeft]
		dataType: variant
		formatString: #,0
		displayFolder: Run Rate
		lineageTag: de6d0405-04a2-41fa-91cf-cdf4b02b8aaf

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Remaining Tget' =
			var lastdatewithSales = CALCULATE(MAX(SALES[Date]),REMOVEFILTERS())
			var Remainingforcast = CALCULATE([TGT],KEEPFILTERS('Calendar'[Date]>lastdatewithSales))
			var ActualSales = [Sale-Value]
			Return
			Remainingforcast
		dataType: variant
		displayFolder: Run Rate
		lineageTag: 03464aab-77ea-450a-a281-3e4508aa77b0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Days Passed' = DISTINCTCOUNT(SALES[Date])
		dataType: variant
		formatString: 0
		displayFolder: Run Rate
		lineageTag: da1b87d3-6d1a-4415-927e-86f94fa819b3

	measure DaysLeft = DATEDIFF ( NOW (), EOMONTH ( NOW (), 0 ), DAY )+1
		dataType: variant
		formatString: 0
		displayFolder: Run Rate
		lineageTag: efc9bdfe-60c4-4776-bf20-db2d9685543e

