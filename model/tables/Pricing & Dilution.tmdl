		lineageTag: 0a2e2bb1-f2b1-4789-b2fb-0ff8568f5a2c

	measure 'MTD Dilution%' = IFERROR(([MTD Full Price Sales]-[MTD Sales])/[MTD Full Price Sales],"")
		dataType: variant
		formatString: 0%;-0%;0%
		displayFolder: Dilution\MTD
		lineageTag: 542c9a0e-0b2d-4138-b185-b1eedc78fcf6

	measure 'LY MTD DILUTION%' = DIVIDE([LY MTD Full Sales]-[LY MTD Sales],[LY MTD Full Sales])
