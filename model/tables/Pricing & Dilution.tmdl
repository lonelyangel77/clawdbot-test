		formatString: 0%;-0%;0%
		displayFolder: Dilution\MTD
		lineageTag: e60cba71-0e87-4925-b6f8-79ab32a2ccba

	measure 'YTD Dilution%' = DIVIDE([YTD Full Sales]-[YTD Sales],[YTD Full Sales])
		dataType: variant
