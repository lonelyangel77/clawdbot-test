		lineageTag: 60a3ec59-dd08-4708-bd0b-5c3d0415dd7f

	measure 'YTD Dilution Short%' = [YTD Dilution Var%]/[LYTD Dilution%]
		dataType: variant
		formatString: 0%;-0%;0%
		displayFolder: Dilution\YTD
		lineageTag: 26146aec-ceae-4e20-b33a-4b6aaf3ba69b

	measure Disct% =
			VAR FullPrice =SUM(SALES[Base Price])
			VAR Soldprice =SUM(SALES[Sold Price])
			Return
			(fullprice-Soldprice)/FullPrice
		dataType: variant
		formatString: 0%;-0%;0%
		displayFolder: Discount
		lineageTag: 784c96ed-1d79-434e-a814-a3646a73409f

	measure 'Discount (V) Sale' = [Full Price Sale Vaule]-[Sale-Value]
		dataType: variant
		displayFolder: Discount
		lineageTag: 3c5edfa5-ec5b-414a-8d19-ddb6eff61402

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Full Price Sale Vaule' =
			SUMX(
			        SALES,
			        SALES[QtySold] * RELATED('Product'[RetailPrice1])
			    )
		dataType: variant
		formatString: #,0
		displayFolder: Full Price
		lineageTag: 2bbf33c5-ac65-47b0-b8f0-ada557a70521

	measure 'LY Full Price Sale' = CALCULATE([Full Price Sale Vaule],SAMEPERIODLASTYEAR('Calendar'[Date]))
		dataType: variant
		formatString: #,0
		displayFolder: Full Price
		lineageTag: 8c1281e8-3358-4ce9-ac8c-fd775c9c7a68

	measure 'LY MTD Full Sales' = CALCULATE([MTD Full Price Sales],SAMEPERIODLASTYEAR('calendar'[Date]))
