		displayFolder: Dilution\YTD
		lineageTag: 3dbb1900-7714-45bf-99d3-c2e305086360

	measure 'LYTD Dilution%' = DIVIDE([LYTD Full Sales]-[LYTD Sales],[LYTD Full Sales])
