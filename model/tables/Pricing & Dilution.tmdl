table 'Pricing & Dilution'
	isHidden

	measure Dilution% = ([Full Price Sale Vaule]-[Sale-Value])/[Full Price Sale Vaule]
		dataType: variant
		formatString: 0%;-0%;0%
		displayFolder: Dilution
		lineageTag: aee8bd96-34bd-4c3f-8fdd-bc1392fe04d9

		changedProperty = FormatString

	measure 'Dilution (V)' = [Full Price Sale Vaule]-[Sale-Value]
		dataType: variant
		formatString: #,0
		displayFolder: Dilution
		lineageTag: 4b81e7c9-ae35-4b37-9605-c8aeeef86201

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'LY Dilution' = DIVIDE(([LY Full Price Sale]-[LY Sales]),[LY Full Price Sale])
		dataType: variant
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Dilution
		lineageTag: 58e21659-92cb-403a-a5ac-77470e1bccf4

	measure 'Dilution% Var' = [Dilution%]-[LY Dilution]
		dataType: variant
		formatString: 0.0%;-0.0%;0.0%
